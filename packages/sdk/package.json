{
  "name": "@lora/sdk",
  "version": "0.0.1",
  "description": "Typed TypeScript client for the LORA API, generated from its OpenAPI contract.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../openapi.json --output src/generated/schema.ts",
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "typecheck": "pnpm run generate && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
