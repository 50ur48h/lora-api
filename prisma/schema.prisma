// LORA — Prisma schema (Phase 0)
// Every tenant-owned table carries `tenantId` (required for RLS) and is indexed on it.
// Money is stored as integer cents. Default timezone Asia/Kuala_Lumpur.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------
enum Role {
  PLATFORM_ADMIN
  TENANT_OWNER
  STORE_MANAGER
  STAFF
  CUSTOMER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum LedgerType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
  REVERSE
}

enum LedgerStatus {
  PENDING
  CONFIRMED
  REVERSED
}

enum CouponType {
  PERCENT
  FIXED
}

enum NotifChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotifStatus {
  QUEUED
  SENT
  FAILED
}

// ---------- Tenancy ----------
model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  status    TenantStatus @default(ACTIVE)
  plan      String       @default("trial")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  stores    Store[]
  users     User[]
  auditLogs AuditLog[]
}

model Store {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  slug            String   @unique
  timezone        String   @default("Asia/Kuala_Lumpur")
  stripeAccountId String?
  customDomain    String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  staff           Staff[]
  services        Service[]
  theme           Theme?
  coupons         Coupon[]
  bookings        Booking[]

  @@index([tenantId])
}

// User.id mirrors the Supabase auth user id (sub claim).
model User {
  id        String   @id @db.Uuid
  tenantId  String?  @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  email     String   @unique
  role      Role     @default(CUSTOMER)
  storeId   String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ---------- Operations ----------
model Staff {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  storeId      String         @db.Uuid
  store        Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  photoUrl     String?
  jobTitle     String?
  bio          String?
  active       Boolean        @default(true)
  availability Availability[]
  bookings     Booking[]

  @@index([tenantId])
  @@index([storeId])
}

model Service {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  storeId     String    @db.Uuid
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  durationMin Int
  bufferMin   Int       @default(0)
  priceCents  Int
  active      Boolean   @default(true)
  bookings    Booking[]

  @@index([tenantId])
  @@index([storeId])
}

model Availability {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  staffId   String @db.Uuid
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday   Int // 0-6
  startTime String // "09:00"
  endTime   String // "17:00"

  @@index([tenantId])
  @@index([staffId])
}

model Customer {
  id        String               @id @default(uuid()) @db.Uuid
  tenantId  String               @db.Uuid
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime             @default(now())
  bookings  Booking[]
  loyalty   LoyaltyMembership?
  ledger    LoyaltyLedgerEntry[]

  @@index([tenantId])
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  reference    String        @unique
  tenantId     String        @db.Uuid
  storeId      String        @db.Uuid
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId   String        @db.Uuid
  customer     Customer      @relation(fields: [customerId], references: [id])
  staffId      String        @db.Uuid
  staff        Staff         @relation(fields: [staffId], references: [id])
  serviceId    String        @db.Uuid
  service      Service       @relation(fields: [serviceId], references: [id])
  startAt      DateTime
  endAt        DateTime
  status       BookingStatus @default(REQUESTED)
  depositCents Int           @default(0)
  payment      Payment?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([storeId, startAt])
  @@index([staffId, startAt])
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  bookingId       String        @unique @db.Uuid
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stripePaymentId String?
  amountCents     Int
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  @@index([tenantId])
}

// ---------- Branding & promotions ----------
model Theme {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @db.Uuid
  storeId  String  @unique @db.Uuid
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  logoUrl  String?
  colors   Json    @default("{}")
  fonts    Json    @default("{}")
  images   Json    @default("{}")

  @@index([tenantId])
}

model Coupon {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @db.Uuid
  storeId    String     @db.Uuid
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code       String
  type       CouponType
  value      Int
  validFrom  DateTime?
  validTo    DateTime?
  usageLimit Int?
  usedCount  Int        @default(0)
  active     Boolean    @default(true)

  @@unique([storeId, code])
  @@index([tenantId])
}

// ---------- Loyalty (modeled now, logic in Phase 3) ----------
model LoyaltyMembership {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  customerId String   @unique @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier       String   @default("bronze")
  status     String   @default("active")
  joinedAt   DateTime @default(now())

  @@index([tenantId])
}

model LoyaltyLedgerEntry {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid
  customerId String       @db.Uuid
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       LedgerType
  status     LedgerStatus @default(PENDING)
  points     Int
  reason     String
  bookingId  String?      @db.Uuid
  createdAt  DateTime     @default(now())
  settledAt  DateTime?

  @@index([tenantId])
  @@index([customerId, status])
}

// ---------- Cross-cutting ----------
model Notification {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  bookingId String?      @db.Uuid
  channel   NotifChannel
  template  String
  status    NotifStatus  @default(QUEUED)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([tenantId])
}

// Audit log powers the data-ownership "who accessed what" guarantee.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId   String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
