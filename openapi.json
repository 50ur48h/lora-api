{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getInfo",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "root"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The Health Check is successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {},
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "The Health Check is not successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        },
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    },
    "/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/public/stores/{slug}": {
      "get": {
        "operationId": "PublicController_getStore",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicStoreResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "public"
        ]
      }
    },
    "/v1/public/stores/{slug}/services/{serviceId}/availability": {
      "get": {
        "operationId": "PublicController_getAvailability",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serviceId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": true,
            "in": "query",
            "description": "Target day in the store timezone (YYYY-MM-DD).",
            "schema": {
              "example": "2026-07-01",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AvailabilityResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "public"
        ]
      }
    },
    "/v1/stores": {
      "get": {
        "operationId": "StoresController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StoreResponseDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "stores"
        ]
      }
    },
    "/v1/stores/{id}/staff": {
      "get": {
        "operationId": "StoresController_listStaff",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StaffResponseDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "stores"
        ]
      }
    }
  },
  "info": {
    "title": "LORA API",
    "description": "White-label booking platform API",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "PLATFORM_ADMIN",
              "TENANT_OWNER",
              "STORE_MANAGER",
              "STAFF",
              "CUSTOMER"
            ]
          },
          "tenantId": {
            "type": "object",
            "format": "uuid",
            "nullable": true
          },
          "storeId": {
            "type": "object",
            "format": "uuid",
            "nullable": true
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "tenantId",
          "storeId"
        ]
      },
      "PublicThemeDto": {
        "type": "object",
        "properties": {
          "logoUrl": {
            "type": "object",
            "nullable": true
          },
          "colors": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Brand colours, e.g. { \"primary\": \"#0F766E\", \"accent\": \"#F59E0B\" }.",
            "example": {
              "primary": "#0F766E",
              "accent": "#F59E0B"
            }
          },
          "fonts": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Font families, e.g. { \"heading\": \"Playfair Display\", \"body\": \"Inter\" }.",
            "example": {
              "heading": "Playfair Display",
              "body": "Inter"
            }
          }
        },
        "required": [
          "logoUrl",
          "colors",
          "fonts"
        ]
      },
      "PublicServiceDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "durationMin": {
            "type": "number",
            "description": "Duration in minutes."
          },
          "priceCents": {
            "type": "number",
            "description": "Price in cents (MYR)."
          }
        },
        "required": [
          "id",
          "name",
          "durationMin",
          "priceCents"
        ]
      },
      "PublicStoreResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "theme": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/PublicThemeDto"
              }
            ]
          },
          "services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicServiceDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "timezone",
          "theme",
          "services"
        ]
      },
      "SlotDto": {
        "type": "object",
        "properties": {
          "startAt": {
            "type": "string",
            "format": "date-time",
            "description": "UTC instant the appointment would start."
          },
          "staffId": {
            "type": "string",
            "format": "uuid",
            "description": "Staff member available for this slot."
          }
        },
        "required": [
          "startAt",
          "staffId"
        ]
      },
      "AvailabilityResponseDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "example": "2026-07-01"
          },
          "slots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SlotDto"
            }
          }
        },
        "required": [
          "date",
          "slots"
        ]
      },
      "StoreResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "timezone": {
            "type": "string",
            "example": "Asia/Kuala_Lumpur"
          },
          "customDomain": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "timezone",
          "customDomain",
          "createdAt"
        ]
      },
      "StaffResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "storeId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "jobTitle": {
            "type": "object",
            "nullable": true
          },
          "photoUrl": {
            "type": "object",
            "nullable": true
          },
          "active": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "storeId",
          "name",
          "jobTitle",
          "photoUrl",
          "active"
        ]
      }
    }
  }
}