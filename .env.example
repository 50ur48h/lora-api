# ─────────────────────────────────────────────────────────────
# LORA API — environment template
# Copy to `.env` and fill in. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=debug

# CORS — comma-separated allowlist of frontend origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Database
# DATABASE_URL connects as the NON-privileged app role (RLS enforced).
# DIRECT_URL connects as a superuser for migrations + seeding (bypasses RLS).
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5432/lora?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/lora?schema=public

# Supabase (local dev can run without a hosted project)
SUPABASE_URL=
SUPABASE_JWT_SECRET=local-dev-super-secret-jwt-key-change-me-in-prod-please-32+
SUPABASE_SERVICE_ROLE_KEY=

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Error tracking (optional in dev)
SENTRY_DSN=

# Stripe (stored now, used in Phase 1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend now; provider is swappable to SendGrid/Twilio later).
# Blank RESEND_API_KEY (or NODE_ENV=test) uses a log-only provider — no sends.
# EMAIL_FROM must be a verified sender in production; onboarding@resend.dev
# only delivers to the Resend account owner in test mode.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
